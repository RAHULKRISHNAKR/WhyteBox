# WhyteBox Environment Configuration
# Copy this file to .env and update values as needed

# ===== Server Configuration =====
FLASK_ENV=development
FLASK_DEBUG=True

# Backend API
BACKEND_HOST=0.0.0.0
BACKEND_PORT=5001

# Frontend Server
FRONTEND_PORT=8000

# ===== File Upload Settings =====
MAX_UPLOAD_SIZE_MB=500
ALLOWED_EXTENSIONS=pth,pt,h5,keras,onnx,pb

# ===== Model Settings =====
# Maximum number of models to keep in cache
MODEL_CACHE_SIZE=5

# Default input shape for models (batch, channels, height, width)
DEFAULT_INPUT_SHAPE=1,3,224,224

# ===== Inference Settings =====
# Maximum number of feature maps to extract per layer
MAX_FEATURE_MAPS=64

# Device for inference (cpu, cuda, mps)
INFERENCE_DEVICE=cpu

# ===== Paths =====
# All paths are relative to backend directory
UPLOAD_FOLDER=models
OUTPUT_FOLDER=output
TEMP_FOLDER=temp

# ===== Logging =====
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
LOG_FILE=logs/whytebox.log

# ===== Performance =====
# Enable parallel processing for conversions
PARALLEL_PROCESSING=False
MAX_WORKERS=4

# ===== Security =====
# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Secret key for sessions (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=your-secret-key-here-change-in-production

# ===== Features =====
# Enable/disable features
ENABLE_EXPLAINABILITY=True
ENABLE_MODEL_COMPARISON=True
ENABLE_VIDEO_INFERENCE=False

# ===== External Services (Optional) =====
# Weights & Biases API key (for experiment tracking)
# WANDB_API_KEY=your-wandb-key

# Hugging Face token (for downloading models)
# HF_TOKEN=your-huggingface-token

# ===== Development =====
# Show detailed error tracebacks in API responses
SHOW_TRACEBACKS=True

# Enable hot reload
HOT_RELOAD=True